{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schemaVersion": "1.0.0",
  "schemaType": "projects",
  "title": "Projects Data Schema",
  "description": "Canonical column definitions for Projects data - source of truth for data bridging",
  "lastUpdated": "2026-02-10",
  "updatedBy": "krush@walmart.com",
  
  "columns": {
    "identifiers": {
      "description": "Unique identifiers for projects and records",
      "fields": [
        {
          "name": "project_id",
          "type": "string",
          "required": true,
          "description": "Unique project identifier",
          "validation": {
            "maxLength": 50,
            "pattern": "^[A-Za-z0-9-_]+$"
          },
          "aliases": ["PROJECT_ID", "ProjectId", "projectId", "id", "ID"]
        },
        {
          "name": "intake_card",
          "type": "string",
          "required": false,
          "description": "Intake card number (Operations/Intake Hub identifier)",
          "validation": {
            "maxLength": 20
          },
          "aliases": ["Intake_Card", "IntakeCard", "intake_card_number"]
        },
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "Project name/title",
          "validation": {
            "minLength": 1,
            "maxLength": 500
          },
          "aliases": ["PROJECT_TITLE", "Title", "project_title", "ProjectTitle", "name", "project_name"]
        }
      ]
    },

    "status": {
      "description": "Project status and health indicators",
      "fields": [
        {
          "name": "status",
          "type": "string",
          "required": true,
          "description": "Current project status",
          "validation": {
            "enum": ["Active", "Archived", "Pending", "Cancelled", "Complete"]
          },
          "aliases": ["Status", "PROJECT_STATUS", "project_status", "state"]
        },
        {
          "name": "phase",
          "type": "string",
          "required": false,
          "description": "Current project phase",
          "validation": {
            "enum": ["Vet", "Test", "Test Markets", "Roll/Deploy", "Complete", "Pending", "Planning"]
          },
          "aliases": ["Phase", "PROJECT_PHASE", "PROJECT_PHASE_2", "project_phase", "stage"]
        },
        {
          "name": "health",
          "type": "string",
          "required": false,
          "description": "Project health status indicator",
          "validation": {
            "enum": ["Green", "Yellow", "Red", "Unknown"]
          },
          "aliases": ["Health", "PROJECT_HEALTH", "health_status"]
        },
        {
          "name": "project_source",
          "type": "string",
          "required": true,
          "autoPopulate": true,
          "description": "Auto-populated from the Data Connection used during upload (not user-selectable)",
          "validation": {
            "enum": ["Operations", "Realty", "Intake Hub", "Manual Upload", "API"]
          },
          "aliases": ["Project_Source", "source", "data_source", "origin"]
        }
      ]
    },

    "location": {
      "description": "Geographic and organizational location data",
      "fields": [
        {
          "name": "division",
          "type": "string",
          "required": false,
          "description": "Division identifier",
          "validation": {
            "enum": ["EAST", "WEST", "NORTH", "SOUTH", "SOUTHEAST", "SOUTHWEST", "NHM", "SAM"]
          },
          "aliases": ["Division", "DIVISION", "div"]
        },
        {
          "name": "region",
          "type": "string",
          "required": false,
          "description": "Region identifier",
          "aliases": ["Region", "REGION", "regional"]
        },
        {
          "name": "market",
          "type": "string",
          "required": false,
          "description": "Market number (3-digit format with leading zeros)",
          "validation": {
            "pattern": "^[0-9]{3}$"
          },
          "transformation": "normalize_market_3digit",
          "aliases": ["Market", "MARKET", "market_number", "mkt"]
        },
        {
          "name": "facility",
          "type": "integer",
          "required": false,
          "description": "Store/facility number",
          "validation": {
            "minimum": 1,
            "maximum": 99999
          },
          "aliases": ["Facility", "FACILITY", "store_number", "store", "Store", "store_id"]
        },
        {
          "name": "city",
          "type": "string",
          "required": false,
          "description": "City name",
          "aliases": ["City", "CITY", "store_city"]
        },
        {
          "name": "state",
          "type": "string",
          "required": false,
          "description": "State code (2-letter)",
          "validation": {
            "pattern": "^[A-Z]{2}$"
          },
          "aliases": ["State", "STATE", "store_state", "state_code"]
        },
        {
          "name": "postal_code",
          "type": "string",
          "required": false,
          "description": "Postal/ZIP code",
          "validation": {
            "pattern": "^[0-9]{5}(-[0-9]{4})?$"
          },
          "aliases": ["Postal_Code", "postal_code", "zip", "zip_code", "ZIP"]
        },
        {
          "name": "latitude",
          "type": "float",
          "required": false,
          "description": "Store latitude coordinate",
          "validation": {
            "minimum": -90,
            "maximum": 90
          },
          "aliases": ["Latitude", "lat", "LAT"]
        },
        {
          "name": "longitude",
          "type": "float",
          "required": false,
          "description": "Store longitude coordinate",
          "validation": {
            "minimum": -180,
            "maximum": 180
          },
          "aliases": ["Longitude", "lng", "long", "LON", "LONG"]
        },
        {
          "name": "store_area",
          "type": "string",
          "required": false,
          "description": "Store area classification",
          "aliases": ["Store_Area", "store_area", "area"]
        },
        {
          "name": "business_area",
          "type": "string",
          "required": false,
          "description": "Business area within store",
          "aliases": ["Business_Area", "business_area", "dept_area"]
        }
      ]
    },

    "time": {
      "description": "Dates, timestamps, and calendar references",
      "fields": [
        {
          "name": "created_date",
          "type": "datetime",
          "required": true,
          "description": "Record creation timestamp",
          "format": "ISO8601",
          "aliases": ["CREATED_TS", "created_at", "create_date", "created"]
        },
        {
          "name": "last_updated",
          "type": "datetime",
          "required": true,
          "description": "Last update timestamp",
          "format": "ISO8601",
          "aliases": ["Last_Updated", "updated_at", "modified_date", "last_modified"]
        },
        {
          "name": "projected_completion",
          "type": "date",
          "required": false,
          "description": "Expected project completion date",
          "format": "YYYY-MM-DD",
          "aliases": ["Projected_Completion_Date", "completion_date", "due_date", "target_date"]
        },
        {
          "name": "wm_week",
          "type": "integer",
          "required": false,
          "description": "Walmart week number",
          "validation": {
            "minimum": 1,
            "maximum": 53
          },
          "aliases": ["WM_Week", "walmart_week", "wm_wk", "week"]
        },
        {
          "name": "fiscal_year",
          "type": "integer",
          "required": false,
          "description": "Walmart fiscal year",
          "validation": {
            "minimum": 2020,
            "maximum": 2099
          },
          "aliases": ["FY", "fiscal_year", "fy", "year"]
        },
        {
          "name": "implementation_week",
          "type": "string",
          "required": false,
          "description": "Implementation week identifier",
          "aliases": ["Implementation_WM_Week", "impl_week", "implementation_wm_week"]
        }
      ]
    },

    "ownership": {
      "description": "Project ownership and personnel",
      "fields": [
        {
          "name": "owner",
          "type": "string",
          "required": false,
          "description": "Project owner name",
          "aliases": ["Owner", "PROJECT_OWNER", "project_owner", "lead", "pm"]
        },
        {
          "name": "director",
          "type": "string",
          "required": false,
          "description": "Director overseeing the project",
          "aliases": ["Director", "DIRECTOR", "director_name"]
        },
        {
          "name": "sr_director",
          "type": "string",
          "required": false,
          "description": "Senior Director overseeing the project",
          "aliases": ["SR_Director", "sr_director", "senior_director", "SrDirector"]
        }
      ]
    },

    "categorization": {
      "description": "Project type and classification fields",
      "fields": [
        {
          "name": "project_type",
          "type": "string",
          "required": false,
          "description": "Type of project",
          "aliases": ["Project_Type", "type", "project_category"]
        },
        {
          "name": "initiative_type",
          "type": "string",
          "required": false,
          "description": "Initiative type or classification",
          "aliases": ["Initiative_Type", "initiative", "initiative_category"]
        },
        {
          "name": "business_type",
          "type": "string",
          "required": false,
          "description": "Business type classification",
          "aliases": ["Business_Type", "business_type", "biz_type"]
        },
        {
          "name": "facility_type",
          "type": "string",
          "required": false,
          "description": "Facility type classification",
          "aliases": ["Facility_Type", "facility_type", "store_type", "format"]
        },
        {
          "name": "partner",
          "type": "string",
          "required": false,
          "description": "Partner organization",
          "aliases": ["Partner", "partner_name", "vendor"]
        },
        {
          "name": "business_organization",
          "type": "string",
          "required": false,
          "description": "Business organization or department",
          "aliases": ["Business_Organization", "business_org", "org", "department"]
        }
      ]
    },

    "impact": {
      "description": "Project impact assessment fields",
      "fields": [
        {
          "name": "associate_impact",
          "type": "string",
          "required": false,
          "description": "Impact description for associates",
          "example": "Associates will need 2 hours training",
          "aliases": ["ASSOCIATE_IMPACT", "associate_impact", "employee_impact"]
        },
        {
          "name": "customer_impact",
          "type": "string",
          "required": false,
          "description": "Impact description for customers",
          "example": "Improved checkout experience",
          "aliases": ["CUSTOMER_IMPACT", "customer_impact", "cx_impact"]
        }
      ]
    },

    "amp_meeting": {
      "description": "AMP Events and Meeting scheduling integration",
      "fields": [
        {
          "name": "amp_event_id",
          "type": "string",
          "required": false,
          "description": "Associated AMP Event ID for this project",
          "example": "AMP-2026-001234",
          "aliases": ["AMP_Event_ID", "amp_id", "event_id", "AMP_ID"]
        },
        {
          "name": "amp_activity_title",
          "type": "string",
          "required": false,
          "description": "AMP Activity title linked to this project",
          "example": "Q1 Self-Checkout Expansion Rollout",
          "aliases": ["AMP_Activity_Title", "amp_title", "activity_title", "AMP_Title"]
        },
        {
          "name": "meeting_type",
          "type": "string",
          "required": false,
          "description": "Type of meeting associated with project",
          "example": "SIF",
          "validation": {
            "enum": ["SIF", "AIM", "Store Meeting", "None"]
          },
          "aliases": ["Meeting_Type", "meeting_type", "mtg_type"]
        },
        {
          "name": "sif_date",
          "type": "date",
          "required": false,
          "description": "Store Impact Forum (SIF) meeting date",
          "example": "2026-03-15",
          "transformation": "to_iso8601",
          "aliases": ["SIF_Date", "sif_date", "SIF_Meeting_Date"]
        },
        {
          "name": "aim_date",
          "type": "date",
          "required": false,
          "description": "Area/Activity Impact Meeting (AIM) date",
          "example": "2026-03-10",
          "transformation": "to_iso8601",
          "aliases": ["AIM_Date", "aim_date", "AIM_Meeting_Date"]
        }
      ]
    },

    "description": {
      "description": "Project descriptions and summaries",
      "fields": [
        {
          "name": "summary",
          "type": "string",
          "required": false,
          "description": "Brief project summary",
          "validation": {
            "maxLength": 2000
          },
          "aliases": ["PRESENTATION_SUMMARY", "summary", "brief", "short_description"]
        },
        {
          "name": "overview",
          "type": "string",
          "required": false,
          "description": "Detailed project overview",
          "validation": {
            "maxLength": 10000
          },
          "aliases": ["OVERVIEW", "overview", "description", "details", "long_description"]
        }
      ]
    }
  },

  "metadata": {
    "totalFields": 40,
    "requiredFields": ["project_id", "title", "status", "project_source", "created_date", "last_updated"],
    "categories": ["identifiers", "status", "location", "time", "ownership", "categorization", "impact", "amp_meeting", "description"]
  }
}
