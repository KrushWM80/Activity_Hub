{
  "name": "@livingdesign/tokens",
  "version": "1.17.0",
  "description": "Living Design System's design tokens.",
  "repository": "https://gecgithub01.walmart.com/LivingDesign/tokens",
  "license": "UNLICENSED",
  "author": "LivingDesignEngineer@email.wal-mart.com",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    "./dist/js/light/mega/components/*": {
      "require": "./dist/js/light/mega/components/*.js",
      "import": "./dist/js/light/mega/components/*.esm.js",
      "types": "./dist/js/light/mega/components/*.d.ts"
    },
    "./dist/js/light/mega/primitive": {
      "require": "./dist/js/light/mega/primitive.js",
      "import": "./dist/js/light/mega/primitive.esm.js",
      "types": "./dist/js/light/mega/primitive.d.ts"
    },
    "./dist/js/light/mega/semantic": {
      "require": "./dist/js/light/mega/semantic.js",
      "import": "./dist/js/light/mega/semantic.esm.js",
      "types": "./dist/js/light/mega/semantic.d.ts"
    },
    "./dist/js/light/mega/icons/semantic": {
      "require": "./dist/js/light/mega/icons/semantic.js",
      "import": "./dist/js/light/mega/icons/semantic.esm.js",
      "types": "./dist/js/light/mega/icons/semantic.d.ts"
    },
    "./dist/js/light/regular/components/*": {
      "require": "./dist/js/light/regular/components/*.js",
      "import": "./dist/js/light/regular/components/*.esm.js",
      "types": "./dist/js/light/regular/components/*.d.ts"
    },
    "./dist/js/light/regular/primitive": {
      "require": "./dist/js/light/regular/primitive.js",
      "import": "./dist/js/light/regular/primitive.esm.js",
      "types": "./dist/js/light/regular/primitive.d.ts"
    },
    "./dist/js/light/regular/semantic": {
      "require": "./dist/js/light/regular/semantic.js",
      "import": "./dist/js/light/regular/semantic.esm.js",
      "types": "./dist/js/light/regular/semantic.d.ts"
    },
    "./dist/js/light/regular/icons/semantic": {
      "require": "./dist/js/light/regular/icons/semantic.js",
      "import": "./dist/js/light/regular/icons/semantic.esm.js",
      "types": "./dist/js/light/regular/icons/semantic.d.ts"
    },
    "./*": "./*"
  },
  "lint-staged": {
    "*.js": [
      "eslint . --fix"
    ]
  },
  "scripts": {
    "build": "ts-node --transpileOnly scripts/build",
    "build-storybook": "storybook build --output-dir dist/storybook-build",
    "clean": "rm -rf Sources/LivingDesignTokens/generated dist library/src/main/res",
    "commitlint": "commitlint --edit $1",
    "lint": "eslint .",
    "prepare": "husky",
    "release": "semantic-release",
    "storybook": "storybook dev -p 6006",
    "test": "jest",
    "typecheck": "tsc",
    "watch": "npm run build && chokidar '{configuration,properties}/**/*.[jt]s' -c 'npm run build'"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.14.0",
    "@livingdesign/bogle": "^0.1.33",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@storybook/addon-essentials": "^8.4.2",
    "@storybook/addon-themes": "^8.4.2",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.5",
    "@storybook/react": "^8.4.2",
    "@storybook/react-webpack5": "^8.4.2",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.9.0",
    "@types/tinycolor2": "^1.4.6",
    "@typescript-eslint/parser": "^8.12.2",
    "chokidar-cli": "^3.0.0",
    "classnames": "^2.5.1",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.12.0",
    "globby": "^11.0.1",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "lodash": "^4.17.21",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semantic-release": "^24.2.0",
    "storybook": "^8.4.2",
    "style-dictionary": "^3.7.2",
    "tinycolor2": "^1.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  },
  "peerDependencies": {
    "@livingdesign/icons": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@livingdesign/icons": {
      "optional": true
    }
  }
}
