{
  "name": "@walmart/gtp-shared-components",
  "version": "2.2.8",
  "description": "Shared components and styles for Living Design themed React Native apps at Walmart",
  "main": "./dist/index.js",
  "types": "./dist/index.d.js",
  "bin": {
    "installFonts": "./scripts/installFonts",
    "runCodemods": "./scripts/runCodemods"
  },
  "files": [
    "assets/",
    "dist/",
    "ax/",
    "src/",
    "transforms/",
    "declarations.d.ts"
  ],
  "comments": {
    "fonts": {
      "updateLocalFonts": "this script runs locally; it copies fonts from node_modules/@livingdesign/fonts -> ./assets/fonts",
      "installFonts": "this script runs on the consumer app; it installs fonts from our dist -> native iOS and native Android. It needs to be run by devs manually using `npx installFonts`"
    },
    "runCodemods": "this script runs on the consumer app; it will automate and modify all the breaking changes when upgrading our library. It needs to be run by devs manually using npx runCodemods <transform> <path>. Please Check Migration using Codemods in CHANGELOG for available transforms.",
    "release": {
      "release:validate": "this script runs on the looper to validate the current and new release version.",
      "release:getAll": "this script runs on the looper to retrieve all the releases in the Shared Component library on github w.r.t Github API.",
      "release:run": "this script will trigger hygen to start releasing the Shared components Library to npme.walmart.com.",
      "release:helper": "this script is meant to give available release options for gtp-shared-components library.",
      "release:generateRelNotes": "this script is meant to generate release notes for changelog from previous released version in gtp-shared-components library."
    },
    "create": {
      "create:component": "this script runs locally to add a new component with template code using hygen.",
      "create:example": "this script runs locally to add a new component example with template code using hygen."
    }
  },
  "scripts": {
    "check:env": "./scripts/checkEnvironment.sh",
    "check:spaces": "./scripts/checkSpaces.sh",
    "check:prData": "npx ts-node ./scripts/checkPrData.ts",
    "build": "npx tsc -p tsconfig.build.json",
    "build:watch": "npx tsc -p tsconfig.build.json --watch",
    "build:noEmit": "npx tsc -p . --noEmit",
    "docs": "npx styleguidist build",
    "docs:dev": "npx styleguidist server",
    "format": "npx prettier --write .",
    "lint": "npx eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:watch": "npx esw . --clear --quiet --watch --ext .js,.jsx,.ts,.tsx",
    "prepublishOnly": "npm run build",
    "updateLocalFonts": "./scripts/updateLocalFonts",
    "test": "npx jest --detectOpenHandles",
    "test:update": "npx jest --updateSnapshot --detectOpenHandles",
    "test:watch": "npx jest --detectOpenHandles --watchAll",
    "jest:coverage": "npx jest --coverage --coverage-provider=v8",
    "create:component": "npx hygen component new",
    "create:example": "npx hygen component screens",
    "release:validate": "npx ts-node ./scripts/validateReleaseVersion.ts",
    "release:getAll": "npx ts-node ./scripts/getAllReleases.ts",
    "release:run": "npx hygen release new",
    "release:helper": "npx ts-node ./scripts/releaseHelper.ts",
    "release:createReleaseBranch": "npx ts-node ./scripts/createReleaseBranch.ts",
    "release:generateRelNotes": "npx ts-node ./scripts/generateReleaseNotes.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://gecgithub01.walmart.com/electrode-mobile-platform/gtp-shared-components.git"
  },
  "license": "Apache-2.0",
  "homepage": "https://gecgithub01.walmart.com/pages/electrode-mobile-platform/gtp-shared-components/",
  "dependencies": {
    "@livingdesign/tokens": "0.74.0",
    "@walmart/gtp-shared-icons": "1.0.10",
    "lodash": "^4.17.15",
    "moment": "^2.29.4",
    "react-keyed-flatten-children": "^1.3.0",
    "react-native-modal": "^13.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-react": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@livingdesign/bogle": "^0.1.25",
    "@react-native-community/datetimepicker": "^6.7.5",
    "@react-native-picker/picker": "^2.4.0",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-navigation/native": "^6.1.9",
    "@testing-library/react-native": "^12.4.1",
    "@tsconfig/react-native": "^3.0.0",
    "@types/jest": "^29.2.1",
    "@types/jscodeshift": "^0.11.11",
    "@types/lodash": "^4.14.155",
    "@types/node": "^18.11.18",
    "@types/node-fetch": "^2.6.9",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "@types/semver": "^7.5.6",
    "babel-jest": "^29.6.3",
    "babel-loader": "^9.1.2",
    "babel-plugin-react-native-web": "^0.18.12",
    "eslint": "^8.31.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-watch": "^8.0.0",
    "jest": "^29.6.3",
    "jest-sonar-reporter": "^2.0.0",
    "mockdate": "^3.0.5",
    "prettier": "2.8.8",
    "react": "18.2.0",
    "react-docgen-typescript": "^2.2.2",
    "react-dom": "18.2.0",
    "react-native": "0.73.8",
    "react-native-device-info": "10.3.0",
    "react-native-drop-shadow": "^0.0.7",
    "react-native-gesture-handler": "^2.9.0",
    "react-native-reanimated": "^3.1.0",
    "react-native-web": "^0.18.10",
    "react-styleguidist": "13.0.0",
    "react-test-renderer": "18.2.0",
    "semver": "^7.5.4",
    "typescript": "5.0.4",
    "url-loader": "^4.1.0",
    "webpack": "^5.75.0"
  },
  "peerDependencies": {
    "@react-native-community/datetimepicker": "*",
    "@react-native-picker/picker": "*",
    "react": "*",
    "react-native": "*",
    "react-native-device-info": "*",
    "react-native-drop-shadow": "*"
  },
  "packageManager": "yarn@4.1.1"
}
