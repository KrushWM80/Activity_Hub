# Zorro Video Generator - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# WALMART GENAI MEDIA STUDIO (Primary - Recommended)
# =============================================================================
# Get SSO token from: https://mediagenai.walmart.com/
# Contact: #help-genai-media-studio for API access
WALMART_SSO_TOKEN=your_sso_token_here
WALMART_MEDIA_STUDIO_API=https://mediagenai.walmart.com/api/v1

# =============================================================================
# LLM PROVIDERS (For Prompt Enhancement)
# =============================================================================
# OpenAI (via Walmart LLM Gateway or direct)
OPENAI_API_KEY=your_openai_key_here

# Azure OpenAI (via Walmart subscription)
AZURE_OPENAI_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here

# Anthropic Claude (if approved)
ANTHROPIC_API_KEY=your_anthropic_key_here

# =============================================================================
# ALTERNATIVE VIDEO PROVIDERS (Fallback - Requires Firewall Access)
# =============================================================================
# ModelScope (External - blocked by Walmart firewall)
MODELSCOPE_TOKEN=your_modelscope_token_here

# Stability AI (External - requires approval)
STABILITY_API_KEY=your_stability_key_here

# RunwayML (External - requires approval)
RUNWAYML_API_KEY=your_runwayml_key_here

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=INFO
ENABLE_METRICS=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
ENVIRONMENT=development
DEBUG=true
