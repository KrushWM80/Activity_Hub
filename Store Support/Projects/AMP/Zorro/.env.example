# Example .env file for Zorro
# Copy this to .env and fill in your actual values

# Environment
ZORRO_ENV=development

# ============================================
# AUTHENTICATION (REQUIRED)
# ============================================
# This project uses Walmart Media Studio API (Google Veo models) ONLY
# NO external providers (OpenAI, Anthropic, etc.) are used
# Authentication is via Walmart SSO token

# Walmart SSO Token (Production: store in Azure Key Vault)
WALMART_SSO_TOKEN=your_walmart_sso_token_here

# ============================================
# WALMART MEDIA STUDIO API
# ============================================
# Production endpoint - confirmed by Oskar/Stephanie (retina-ds team)
# Uses Google Veo models (veo2, veo3) for text-to-video generation
WALMART_MEDIA_STUDIO_API=https://retina-ds-genai-backend.prod.k8s.walmart.net
WALMART_VIDEO_MODEL=veo2  # Options: veo2 (faster), veo3 (higher quality)

# SSL Configuration - REQUIRED for internal Walmart network
# The Media Studio API uses a self-signed certificate
# Set to false for development on internal network
WALMART_SSL_VERIFY=false
# WALMART_CA_BUNDLE=/path/to/walmart-ca-bundle.crt  # For production with proper cert

# Application Settings
DEBUG=true
LOG_LEVEL=INFO

# Video Generation Settings
DEFAULT_VIDEO_DURATION=10
DEFAULT_VIDEO_FPS=24
VIDEO_OUTPUT_DIR=output/videos

# Accessibility Settings
ENABLE_CAPTIONS=true
ENABLE_AUDIO_DESCRIPTION=true
WCAG_LEVEL=AAA

# Performance Settings
MAX_CONCURRENT_GENERATIONS=2
GPU_MEMORY_LIMIT=8GB

# Database Configuration (Production Required)
# DATABASE_URL=postgresql://user:password@localhost:5432/zorro
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# Async Processing (Celery)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI Disclosure (Legal Compliance)
AI_WATERMARK_ENABLED=true
AI_WATERMARK_TEXT=AI Generated
AI_WATERMARK_POSITION=bottom_right
