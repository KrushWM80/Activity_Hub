# Google Cloud / BigQuery
GCP_PROJECT_ID=wmt-assetprotection-prod
BIGQUERY_DATASET=Store_Support_Dev
BIGQUERY_TABLE=IH_Intake_Data

# Option 1: Use gcloud CLI authentication (recommended - easier setup)
# Run: gcloud auth application-default login
# Then leave GOOGLE_APPLICATION_CREDENTIALS empty or commented out

# Option 2: Use service account key file
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# OpenAI (choose one)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Azure OpenAI (alternative to OpenAI)
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# OPENAI_MODEL=gpt-4

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
